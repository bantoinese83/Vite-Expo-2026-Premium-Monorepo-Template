{
  "name": "vite-expo-2026-template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:ox": "turbo lint:ox",
    "lint:fix": "turbo lint:ox -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@vitest/ui": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.0.0",
    "turbo": "latest",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5",
    "web": "workspace:*"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxlint",
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.9"
}
